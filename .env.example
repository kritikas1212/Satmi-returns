# Shopify
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_ACCESS_TOKEN="shpat_xxx"

# Google Sheets
GOOGLE_SHEET_ID=""
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""

# Shiprocket (use API user from Dashboard → Settings → API; not main login if 2FA is on)
# If password has special characters ($ % ^ & !), wrap the whole value in double quotes.
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""

# Warehouse (return destination for RTO; all data auto-filled from here + pincode lookup)
WAREHOUSE_PINCODE="201318"
WAREHOUSE_NAME="Satmi Warehouse"
WAREHOUSE_ADDRESS="Your warehouse address line 1"
WAREHOUSE_PHONE="9999999999"
# Optional: WAREHOUSE_ADDRESS_2, WAREHOUSE_CITY, WAREHOUSE_STATE, WAREHOUSE_COUNTRY (else derived from pincode)

# Firebase (client-side; required for phone OTP auth)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Resend (return label email from support@satmi.in; verify satmi.in in Resend dashboard)
RESEND_API_KEY=""

# App URL (for server-side self-calls: RTO + label + email flow). Use your deployed URL in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
